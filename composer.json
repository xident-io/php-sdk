{
    "name": "xident-io/php-sdk",
    "description": "PHP SDK for Xident age and identity verification",
    "type": "library",
    "license": "MIT",
    "keywords": ["xident", "age-verification", "identity", "sdk", "php"],
    "homepage": "https://docs.xident.io/sdks/php",
    "support": {
        "docs": "https://docs.xident.io/sdks/php",
        "issues": "https://github.com/xident-io/xident-php/issues"
    },
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Xident\\SDK\\": "src/Xident/SDK/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Xident\\SDK\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text --coverage-html=coverage"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
